generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum PointType {
  EARN
  DEDUCT
}

enum RecitationRating {
  VERY_GOOD
  GOOD
  REPEAT
  DID_NOT_MEMORIZE
  MAQRAA
}

model User {
  id           String      @id @default(uuid())
  username     String      @unique
  passwordHash String      @map("password_hash")
  role         Role
  isActive     Boolean     @default(true) @map("is_active")
  lastLogin    DateTime?   @map("last_login")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")
  fcmToken     String?     @map("fcm_token")
  student      Student?
  instructor   Instructor?
  announcement Announcement[]
  @@map("users")
}

model Student {
  id            String          @id @default(uuid())
  userId        String          @unique @map("user_id")
  fullName      String          @map("full_name")
  fatherName    String          @map("father_name")
  dateOfBirth   DateTime        @map("date_of_birth")
  school        String?
  grade         String?
  address       String?
  phone1        String?         @map("phone_1")
  phone2        String?         @map("phone_2")
  instructorId  String          @map("instructor_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  user          User            @relation(fields: [userId], references: [id])
  instructor    Instructor      @relation(fields: [instructorId], references: [id])
  attendance    Attendance[]
  pointsLog     PointsLog[]
  recitations    Recitation[]   
  @@map("students")
}

model Instructor {
  id          String                 @id @default(uuid())
  userId      String                 @unique @map("user_id")
  fullName    String                 @map("full_name")
  dateOfBirth DateTime?              @map("date_of_birth")
  specialty   String?
  address     String?
  mobile      String?
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  user        User                   @relation(fields: [userId], references: [id])
  students    Student[]
  attendance  InstructorAttendance[]

  @@map("instructors")
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String           @map("student_id")
  date      DateTime         @db.Date
  status    AttendanceStatus
  markedBy  String           @map("marked_by")
  notes     String?
  createdAt DateTime         @default(now()) @map("created_at")

  student   Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@map("attendance")
}

model PointCategory {
  id           String      @id @default(uuid())
  name         String
  nameAr       String?     @map("name_ar")
  type         PointType
  defaultValue Int         @map("default_value")
  hasRating    Boolean     @default(false) @map("has_rating")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")

  pointsLog    PointsLog[]

  @@map("point_categories")
}

model PointsLog {
  id          String            @id @default(uuid())
  studentId   String            @map("student_id")
  categoryId  String            @map("category_id")
  amount      Int
  rating      RecitationRating?
  description String?
  awardedBy   String            @map("awarded_by")
  createdAt   DateTime          @default(now()) @map("created_at")

  student     Student           @relation(fields: [studentId], references: [id])
  category    PointCategory     @relation(fields: [categoryId], references: [id])

  @@map("points_log")
}

// ═══════════════════════════════════════════════════════════
// DYNAMIC POINT RULES — Admin-configurable scoring rules
// ═══════════════════════════════════════════════════════════
model PointRule {
  id          String   @id @default(uuid())
  code        String   @unique
  nameAr      String   @map("name_ar")
  description String?
  points      Int
  isPerPage   Boolean  @default(false) @map("is_per_page")
  minPages    Int?     @map("min_pages")
  isAutomatic Boolean  @default(false) @map("is_automatic")
  isDeletable Boolean  @default(false) @map("is_deletable")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
 
  @@map("point_rules")
}

// ═══════════════════════════════════════════════════════════
// GIFTS STORE — Rewards catalog with images and point costs
// ═══════════════════════════════════════════════════════════
model Gift {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageData   String?  @map("image_data") @db.Text
  pointsCost  Int      @map("points_cost")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("gifts")
}

model Recitation {
  id             String            @id @default(uuid())
  studentId      String            @map("student_id")
  instructorId   String            @map("instructor_id")
  surahNumber    Int               @map("surah_number")
  pagesRecited   Float             @default(0) @map("pages_recited")
  isCompleteSura Boolean           @default(false) @map("is_complete_sura")
  rating         RecitationRating
  homework       String?
  date           DateTime          @db.Date
  createdAt      DateTime          @default(now()) @map("created_at")

  student        Student           @relation(fields: [studentId], references: [id])

  @@map("recitations")
}

model InstructorAttendance {
  id           String     @id @default(uuid())
  instructorId String     @map("instructor_id")
  date         DateTime   @db.Date
  present      Boolean    @default(true)
  notes        String?
  createdAt    DateTime   @default(now())
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  @@unique([instructorId, date])
  @@map("instructor_attendance")
}

model Notification {
  id          String    @id @default(uuid())
  senderId    String    @map("sender_id")
  recipientId String?   @map("recipient_id")
  title       String
  body        String
  type        String
  isBroadcast Boolean   @default(false) @map("is_broadcast")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("notifications")
}

model Media {
  id         String   @id @default(uuid())
  uploadedBy String   @map("uploaded_by")
  fileUrl    String   @map("file_url")
  fileType   String   @map("file_type")
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  caption    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("media")
}

model TempAssignment {
  id                   String    @id @default(uuid())
  studentId            String    @map("student_id")
  originalInstructorId String    @map("original_instructor_id")
  tempInstructorId     String    @map("temp_instructor_id")
  startDate            DateTime  @map("start_date") @db.Date
  endDate              DateTime? @map("end_date") @db.Date
  createdAt            DateTime  @default(now()) @map("created_at")

  @@map("temp_assignments")
}

model Announcement {
  id          String    @id @default(uuid())
  title       String
  body        String
  pinned      Boolean   @default(false)
  publishedAt DateTime  @default(now()) @map("published_at")
  expiresAt   DateTime? @map("expires_at")
  createdBy   String    @map("created_by")
  author      User      @relation(fields: [createdBy], references: [id])
  @@map("announcements")
}
